      "id": "a1b2c3d4-0050-0050-0050-000000000050",
      "name": "Merge all",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [180, 320],
      "notes": "Réunit enriched_events + urgent_mails + drafts + deadlines."
    },
    {
      "parameters": {
        "jsCode": "const enriched = $('aggregate_meeting').all().map(i => i.json);\nconst urgents = $('IF urgent').all().map(i => ({\n  from: i.json.from,\n  subject: i.json.subject,\n  reason: i.json.output?.reason\n}));\nconst drafts = $('create_draft').all().map(i => ({\n  subject: i.json.subject || i.json.message?.subject,\n  id: i.json.id\n}));\nconst deadlines = $('extract_deadlines').first()?.json?.output?.deadlines || [];\nreturn [{\n  json: {\n    date: new Date().toISOString().slice(0, 10),\n    enriched_events: enriched,\n    urgent_mails: urgents,\n    drafts_created: drafts,\n    deadlines\n  }\n}];"
      },
