    {
      "parameters": {
        "promptType": "define",
        "text": "=Tu rédiges une réponse polie et concise en français.\nNe signe pas le mail.\n\nMail original :\n  De      : {{ $('Loop Mails').item.json.from }}\n  Sujet   : {{ $('Loop Mails').item.json.subject }}\n  Aperçu  : {{ $('Loop Mails').item.json.snippet }}\n\nProduis uniquement le corps de la réponse (texte brut, 4-6 lignes max).",
        "options": {}
      },
      "id": "a1b2c3d4-0031-0031-0031-000000000031",
      "name": "draft_body",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [-240, 100]
    },
    {
      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {
          "temperature": 0.3,
          "baseURL": "https://api.groq.com/openai/v1"
        }
      },
      "id": "a1b2c3d4-0032-0032-0032-000000000032",
      "name": "LLM Groq draft",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "typeVersion": 1.2,
      "position": [-280, 280],
      "credentials": {
        "openAiApi": {
          "id": "groq",
          "name": "Groq"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Idempotence : on ne crée un draft que si aucun draft du jour ne l'a déjà fait.\nconst today = new Date().toISOString().slice(0, 10);\nconst marker = `[briefing-${today}]`;\nconst mail = $('Loop Mails').item.json;\nconst subj = mail.subject || '';\nif (subj.includes(marker)) {\n  return [];\n}\nconst fromRaw = mail.from || '';\nconst toEmail = (fromRaw.match(/<([^>]+)>/) || [null, fromRaw])[1];\nreturn [{\n  json: {\n    to: toEmail,\n    subject: `Re: ${subj} ${marker}`,\n    body: $json.output,\n    threadId: mail.threadId\n  }\n}];"
      },
      "id": "a1b2c3d4-0033-0033-0033-000000000033",
      "name": "prepare_draft",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-40, 100]
    },
