      "parameters": {
        "resource": "draft",
        "subject": "={{ $json.subject }}",
        "emailType": "text",
        "message": "={{ $json.body }}",
        "options": {
          "sendTo": "={{ $json.to }}",
          "threadId": "={{ $json.threadId }}"
        }
      },
      "id": "a1b2c3d4-0034-0034-0034-000000000034",
      "name": "create_draft",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
