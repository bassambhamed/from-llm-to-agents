      },
      "id": "a1b2c3d4-0044-0044-0044-000000000044",
      "name": "Parser deadlines",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.2,
      "position": [-580, 660]
    },
    {
      "parameters": {
